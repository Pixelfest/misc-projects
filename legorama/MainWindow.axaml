<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Legorama.MainWindow"
        x:CompileBindings="False"
        Title="Legorama"
        RequestedThemeVariant="Dark"
        Background="#151515"
        Foreground="#F2F2F2"
        Width="1280"
        Height="720"
        KeyDown="OnMainWindowKeyDown">
    <Grid Background="#151515">
        <Grid IsVisible="{Binding IsSetupMode}" ColumnDefinitions="320,*" Margin="16" ColumnSpacing="16">
            <Border Grid.Column="0" Padding="12" Background="#242424" CornerRadius="8">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                    <TextBlock Text="Entries" FontSize="20" FontWeight="SemiBold" Foreground="#F2F2F2" />

                    <ListBox Grid.Row="1"
                             Background="#2D2D2D"
                             Foreground="#F2F2F2"
                             ItemsSource="{Binding Entries}"
                             SelectedItem="{Binding SelectedEntry, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding EntryName}" Foreground="#F2F2F2" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Spacing="8">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Content="Add" Click="AddEntry_Click" />
                            <Button Grid.Column="1" Content="Delete" Click="DeleteEntry_Click" IsEnabled="{Binding HasSelectedEntry}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Content="Move Up" Click="MoveUp_Click" IsEnabled="{Binding HasSelectedEntry}" />
                            <Button Grid.Column="1" Content="Move Down" Click="MoveDown_Click" IsEnabled="{Binding HasSelectedEntry}" />
                        </Grid>
                        <Button Content="Show details" Click="BeginEditEntry_Click" IsVisible="{Binding IsNotEditingEntry}" IsEnabled="{Binding HasSelectedEntry}" />
                        <Button Content="Hide details" Click="CancelEdit_Click" IsVisible="{Binding IsEditingEntry}" />
                        <Button Content="Start Presentation" Click="StartPresentation_Click" IsEnabled="{Binding HasEntries}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="16" Background="#202020" CornerRadius="8">
                <Grid>
                    <StackPanel IsVisible="{Binding IsNotEditingEntry}" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                        <TextBlock Text="Select an entry and use Show details on the left to edit."
                                   Foreground="#F2F2F2"
                                   TextAlignment="Center" />
                    </StackPanel>

                    <ScrollViewer IsVisible="{Binding IsEditingEntry}">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="10" ColumnDefinitions="220,*">
                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Entry Setup" FontSize="22" FontWeight="SemiBold" Foreground="#F2F2F2" Margin="0,0,0,6" />

                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Entry name" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditingEntry.EntryName, Mode=TwoWay}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Question" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditingEntry.Question, Mode=TwoWay}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Left image" />
                            <Grid Grid.Row="3" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0" Text="{Binding EditingEntry.LeftImagePath, Mode=TwoWay}" />
                                <Button Grid.Column="1" Content="Browse" Click="BrowseLeftImage_Click" />
                            </Grid>

                            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Top" Text="Left preview" />
                            <Border Grid.Row="4" Grid.Column="1" Height="150" Background="#2A2A2A" CornerRadius="6" Padding="6">
                                <Image Source="{Binding EditingLeftImage}" Stretch="Uniform" />
                            </Border>

                            <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Left reveal text" />
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EditingEntry.LeftRevealText, Mode=TwoWay}" />

                            <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Left reveal color" />
                            <ComboBox Grid.Row="6" Grid.Column="1"
                                      ItemsSource="{Binding RevealColors}"
                                      SelectedItem="{Binding EditingEntry.LeftRevealColor, Mode=TwoWay}" />

                            <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Right image" />
                            <Grid Grid.Row="7" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0" Text="{Binding EditingEntry.RightImagePath, Mode=TwoWay}" />
                                <Button Grid.Column="1" Content="Browse" Click="BrowseRightImage_Click" />
                            </Grid>

                            <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Top" Text="Right preview" />
                            <Border Grid.Row="8" Grid.Column="1" Height="150" Background="#2A2A2A" CornerRadius="6" Padding="6">
                                <Image Source="{Binding EditingRightImage}" Stretch="Uniform" />
                            </Border>

                            <TextBlock Grid.Row="9" Grid.Column="0" VerticalAlignment="Center" Text="Right reveal text" />
                            <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding EditingEntry.RightRevealText, Mode=TwoWay}" />

                            <TextBlock Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" Text="Right reveal color" />
                            <ComboBox Grid.Row="10" Grid.Column="1"
                                      ItemsSource="{Binding RevealColors}"
                                      SelectedItem="{Binding EditingEntry.RightRevealColor, Mode=TwoWay}" />

                            <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <TextBlock Text="{Binding SaveFeedbackMessage}"
                                           IsVisible="{Binding IsSaveFeedbackVisible}"
                                           Foreground="#9FD3A8"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <Button Content="Save" Click="SaveEntry_Click" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsPresentationMode}" Background="#111111" RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0" Background="#1B1B1B" Margin="12,12,12,8" CornerRadius="8" Padding="10">
                <TextBlock Text="{Binding CurrentQuestion}"
                           Foreground="#F2F2F2"
                           FontSize="42"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxLines="2" />
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12" Margin="12,0,12,8">
                <Grid Grid.Column="0" RowDefinitions="8*,2*" RowSpacing="12">
                    <Border Grid.Row="0" Background="#2A2A2A" CornerRadius="8">
                        <Image Source="{Binding CurrentLeftImage}" Stretch="Uniform" />
                    </Border>
                    <Border Grid.Row="1" Background="#1B1B1B" CornerRadius="8" Padding="10">
                        <TextBlock Text="{Binding CurrentLeftRevealText}"
                                   Foreground="{Binding CurrentLeftRevealBrush}"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>
                </Grid>

                <Grid Grid.Column="1" RowDefinitions="8*,2*" RowSpacing="12">
                    <Border Grid.Row="0" Background="#2A2A2A" CornerRadius="8">
                        <Image Source="{Binding CurrentRightImage}" Stretch="Uniform" />
                    </Border>
                    <Border Grid.Row="1" Background="#1B1B1B" CornerRadius="8" Padding="10">
                        <TextBlock Text="{Binding CurrentRightRevealText}"
                                   Foreground="{Binding CurrentRightRevealBrush}"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="12,0,12,12">
                <Button Grid.Column="0" Content="Back to Setup" Click="ReturnToSetup_Click" />
                <TextBlock Grid.Column="1"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#F2F2F2"
                           Text="Keys: R = reveal, Space/Right = next, Left = previous, Esc = setup" />
            </Grid>
        </Grid>
    </Grid>
</Window>
